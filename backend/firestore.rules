rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 記事・日次データは公開読み取り
    match /articles/{articleId} {
      allow read: if true;
      allow write: if false;
    }
    match /days/{dayKey} {
      allow read: if true;
      allow write: if false;
    }

    // ユーザー自身のデータのみ
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /bookmarks/{bookmarkId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // 管理データは非公開
    match /sources/{sourceId} { allow read, write: if false; }
    match /configs/{configId} { allow read, write: if false; }
    match /runs/{runId} { allow read, write: if false; }
    match /candidates/{candidateId} { allow read, write: if false; }
  }
}
